{
  "compilerOptions": {
    "target": "ES2023",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "types": ["vite/client"],
    "skipLibCheck": true,

    /* Bundler mode 複数のファイルを1つにまとめたバンドラー用の設定 */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true, // .tsの拡張子をつけてインポートしていい
    "verbatimModuleSyntax": true, // import type と普通の import を厳密に分ける
    "moduleDetection": "force",
    "noEmit": true,

    /* Linting */
    // https://www.typescriptlang.org/tsconfig/
    "strict": true, // lintを厳格に
    "noUnusedLocals": true, // 使っていない変数の引数があるとエラー
    "noUnusedParameters": true, // 使っていない関数の引数があるとエラー
    "erasableSyntaxOnly": true, // JSに変換した時に複雑なコードが残るものの使用を制限し
    "noFallthroughCasesInSwitch": true, // switch 文で break を忘れて次の case に突入するのを防ぐ
    "noUncheckedSideEffectImports": true // import "./style.css" のような中身の関数などを使わないインポートが、実際に利用されているか
  },
  "include": ["src"]
}
